# YouTube videos data endpoint (JSON)
# Used in: src/app/lib/data.ts (getYouTubeData)
YOUTUBE_VIDEO_DATA=https://www.mychicmirror.com/API/fetchVideos.php

# Main cover image URL
# Used in: src/app/page.tsx
